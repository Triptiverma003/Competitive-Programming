#include<bits/stdc++.h>
using namespace std;
//Declaring One function to calculate the BFS.

vector<int>BFS(vector<vector<int>>V, int src){
	vector<int>res; vector<bool>check(V.size(), false);
	src = 0; 
	queue<int>q;
	q.push(src);
	
	check[src] = true;
	while(!q.empty()){
		int curr = q.front();
		res.push_back(curr);
		q.pop();
		
		for(int x : V[curr]){
			if(!check[x]){
				check[x] = true;
				q.push(x);
			}
		}
	}
	return res;
}

int main() {
     vector<vector<int>> V = {
         {1, 2},
         {0, 3},
      {0},
       {1}
    };

     vector<int> ans = BFS(V, 0);
    for(int x : ans) cout << x << " ";
}
